frase =  str(input('Digite uma frase: ')).strip().upper()
print('A letra A aparece {} vezes na frase'.format(frase.count('A'))) #count: conta quantas vezes um caracteres existe na frase.
print('A primeira letra A apareceu na posição {}'.format(frase.find('A')+1)) #find: conta a partir da posição encontrou os caracteres
print('A última LETRA A apareceu na posição {}'.format(frase.rfind('A')+1)) #find: conta a partir da posição encontrou os caracteres, porém em right|Esquerda.
